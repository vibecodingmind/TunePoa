// TunePoa - Ringback Tone Management Platform
// Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String   @unique
  businessName  String
  businessCategory String @default("general")
  role          String   @default("BUSINESS_OWNER") // SUPER_ADMIN, ADMIN, STUDIO_MANAGER, BUSINESS_OWNER
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, INACTIVE
  password      String?  // hashed password for direct login
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  serviceRequests    ServiceRequest[]
  subscriptions      Subscription[]
  activityLogs       ActivityLog[]
}

// ==================== SERVICE REQUESTS ====================

model ServiceRequest {
  id                String   @id @default(cuid())
  userId            String
  businessName      String
  businessCategory  String
  adType            String   @default("PROMO") // PROMO, BRANDING, OFFER, ANNOUNCEMENT
  targetAudience    String?
  adScript          String
  preferredLanguage String   @default("swahili")
  specialInstructions String?
  status            String   @default("PENDING") // PENDING, IN_PROGRESS, RECORDING, AWAITING_VERIFICATION, APPROVED, REJECTED, COMPLETED
  assignedTo        String?  // studio manager user ID
  rejectionReason   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User       @relation(fields: [userId], references: [id])
  recordings        Recording[]
  subscriptions     Subscription[]
  whatsappVerifications WhatsAppVerification[]

  @@index([userId])
  @@index([status])
}

// ==================== RECORDINGS ====================

model Recording {
  id            String   @id @default(cuid())
  requestId     String
  title         String
  fileName      String
  filePath      String
  fileSize      Int      @default(0)
  duration      Int      @default(0) // in seconds
  format        String   @default("MP3")
  status        String   @default("DRAFT") // DRAFT, FINAL, APPROVED, REJECTED
  recordedBy    String?  // studio manager user ID
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request       ServiceRequest  @relation(fields: [requestId], references: [id])
  whatsappVerifications WhatsAppVerification[]

  @@index([requestId])
}

// ==================== WHATSAPP VERIFICATIONS ====================

model WhatsAppVerification {
  id            String   @id @default(cuid())
  recordingId   String
  requestId     String
  phoneNumber   String
  messageStatus String   @default("PENDING") // PENDING, SENT, DELIVERED, READ, RESPONDED, FAILED
  response      String?  // APPROVED or REJECTED
  responseNotes String?
  sentAt        DateTime?
  respondedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recording     Recording      @relation(fields: [recordingId], references: [id])
  request       ServiceRequest @relation(fields: [requestId], references: [id])

  @@index([recordingId])
  @@index([requestId])
}

// ==================== PACKAGES ====================

model Package {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Float
  currency      String   @default("TZS")
  durationMonths Int
  features      String   // JSON string of features
  maxAdDuration Int      @default(30) // max ad duration in seconds
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

// ==================== SUBSCRIPTIONS ====================

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  packageId       String
  requestId       String   @unique
  startDate       DateTime?
  endDate         DateTime?
  status          String   @default("PENDING") // PENDING, ACTIVE, EXPIRED, CANCELLED, SUSPENDED
  amount          Float
  currency        String   @default("TZS")
  paymentStatus   String   @default("UNPAID") // UNPAID, PAID, OVERDUE, REFUNDED
  mnoProviderId   String?
  mnoReference    String?  // reference from MNO
  mnoStatus       String   @default("NOT_SUBMITTED") // NOT_SUBMITTED, PENDING_MNO, ACTIVE_MNO, FAILED_MNO, REMOVED_MNO
  mnoSubmittedAt  DateTime?
  mnoActivatedAt  DateTime?
  phoneNumber     String?  // the phone number with ringback tone
  autoRenew       Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  package         Package         @relation(fields: [packageId], references: [id])
  request         ServiceRequest  @relation(fields: [requestId], references: [id])
  mnoProvider     MnoProvider?    @relation(fields: [mnoProviderId], references: [id])
  payments        Payment[]

  @@index([userId])
  @@index([status])
  @@index([packageId])
}

// ==================== MNO PROVIDERS ====================

model MnoProvider {
  id          String   @id @default(cuid())
  name        String   @unique
  country     String   @default("Tanzania")
  code        String   @unique // VODACOM, AIRTEL, etc
  apiEndpoint String?
  apiKey      String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@index([code])

  @@map("mno_providers")
}

// ==================== PAYMENTS ====================

model Payment {
  id              String   @id @default(cuid())
  subscriptionId  String
  amount          Float
  currency        String   @default("TZS")
  method          String   @default("M_PESA") // M_PESA, TIGO_PESA, AIRTEL_MONEY, BANK, CASH
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  reference       String?  // transaction reference
  paidAt          DateTime?
  verifiedBy      String?  // admin who verified
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
}

// ==================== ACTIVITY LOGS ====================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // CREATED, UPDATED, DELETED, STATUS_CHANGE, LOGIN, etc
  entityType  String   // USER, SERVICE_REQUEST, RECORDING, SUBSCRIPTION, etc
  entityId    String?
  details     String   // JSON string with details
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}
