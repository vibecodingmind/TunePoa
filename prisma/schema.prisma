// TunePoa - Ringback Tone Management Platform
// Database Schema
//
// Simplified Flow:
//   1. User creates service request + pays → PENDING
//   2. Admin reviews → APPROVED or REJECTED
//   3. On APPROVED → subscription is created automatically
//   4. User can re-submit if REJECTED

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String   @unique
  businessName  String
  businessCategory String @default("general")
  role          String   @default("BUSINESS_OWNER") // SUPER_ADMIN, ADMIN, BUSINESS_OWNER
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, INACTIVE
  password      String?  // hashed password for direct login
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  serviceRequests    ServiceRequest[]
  subscriptions      Subscription[]
  activityLogs       ActivityLog[]
}

// ==================== SERVICE REQUESTS ====================

model ServiceRequest {
  id                String   @id @default(cuid())
  userId            String
  businessName      String
  businessCategory  String
  adType            String   @default("PROMO") // PROMO, BRANDING, OFFER, ANNOUNCEMENT
  targetAudience    String?
  adScript          String
  preferredLanguage String   @default("swahili")
  specialInstructions String?
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User       @relation(fields: [userId], references: [id])
  subscriptions     Subscription[]

  @@index([userId])
  @@index([status])
}

// ==================== PRICING TIERS ====================
// Admin-managed pricing matrix: user-count ranges × duration discounts

model PricingTier {
  id            String   @id @default(cuid())
  name          String   // e.g. "1-10", "11-25", "25-50", "50+"
  minUsers      Int      // e.g. 1, 11, 25, 50
  maxUsers      Int      // e.g. 10, 25, 50, 999
  price1Month   Float    // per-user price for 1-month subscription
  price3Month   Float    // per-user price for 3-month subscription
  price6Month   Float    // per-user price for 6-month subscription
  price12Month  Float    // per-user price for 12-month subscription
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

// Global pricing settings managed by admin
model PricingSettings {
  id                  String   @id @default(cuid())
  key                 String   @unique  // e.g. "audio_recording_price", "starter_package_price"
  value               String   // stored as string, parsed as needed
  label               String   // human-readable label for admin UI
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ==================== PACKAGES ====================
// Kept for backward compatibility; new subscriptions use PricingTier

model Package {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Float
  currency      String   @default("TZS")
  durationMonths Int
  features      String   // JSON string of features
  maxAdDuration Int      @default(30) // max ad duration in seconds
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

// ==================== SUBSCRIPTIONS ====================

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  packageId       String?
  pricingTierId   String?
  requestId       String   @unique
  startDate       DateTime?
  endDate         DateTime?
  status          String   @default("PENDING") // PENDING, ACTIVE, EXPIRED, CANCELLED, SUSPENDED
  amount          Float    // total amount (price × userCount × duration)
  unitPrice       Float    @default(0)  // per-user per-month price from PricingTier
  userCount       Int      @default(1)  // number of users/numbers
  durationMonths  Int      @default(1)  // subscription duration in months
  includesAudio   Boolean  @default(false) // whether audio recording is included
  currency        String   @default("TZS")
  paymentStatus   String   @default("UNPAID") // UNPAID, PAID, OVERDUE, REFUNDED
  mnoProviderId   String?
  mnoReference    String?  // reference from MNO
  mnoStatus       String   @default("NOT_SUBMITTED") // NOT_SUBMITTED, PENDING_MNO, ACTIVE_MNO, FAILED_MNO, REMOVED_MNO
  mnoSubmittedAt  DateTime?
  mnoActivatedAt  DateTime?
  phoneNumber     String?  // the phone number with ringback tone
  autoRenew       Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  package         Package?        @relation(fields: [packageId], references: [id])
  pricingTier     PricingTier?    @relation(fields: [pricingTierId], references: [id])
  request         ServiceRequest  @relation(fields: [requestId], references: [id])
  mnoProvider     MnoProvider?    @relation(fields: [mnoProviderId], references: [id])
  payments        Payment[]

  @@index([userId])
  @@index([status])
  @@index([packageId])
  @@index([pricingTierId])
}

// ==================== MNO PROVIDERS ====================

model MnoProvider {
  id          String   @id @default(cuid())
  name        String   @unique
  country     String   @default("Tanzania")
  code        String   @unique // VODACOM, AIRTEL, etc
  apiEndpoint String?
  apiKey      String?
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@index([code])

  @@map("mno_providers")
}

// ==================== PAYMENTS ====================

model Payment {
  id              String   @id @default(cuid())
  subscriptionId  String
  amount          Float
  currency        String   @default("TZS")
  method          String   @default("M_PESA") // M_PESA, TIGO_PESA, AIRTEL_MONEY, BANK, CASH
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  reference       String?  // transaction reference
  paidAt          DateTime?
  verifiedBy      String?  // admin who verified
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
}

// ==================== ACTIVITY LOGS ====================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // CREATED, UPDATED, DELETED, STATUS_CHANGE, LOGIN, etc
  entityType  String   // USER, SERVICE_REQUEST, SUBSCRIPTION, etc
  entityId    String?
  details     String   // JSON string with details
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}
