# Database (PostgreSQL) - Railway will inject this automatically
DATABASE_URL="postgresql://user:password@localhost:5432/tunepoa"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

# Pesapal (Tanzania - Mobile Money & Cards)
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
