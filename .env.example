# =============================================================================
# TunePoa - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the app.
# NEVER commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Railway injects DATABASE_URL automatically. For local dev, use:
#   postgresql://user:password@localhost:5432/tunepoa
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/tunepoa"

# -----------------------------------------------------------------------------
# App
# NEXT_PUBLIC_APP_URL: The public URL of your app (no trailing slash).
#   - Local dev: http://localhost:3000
#   - Production: https://tunepoa.co.tz
# NODE_ENV: Set to "production" on Railway/deployed environments.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Authentication
# TOKEN_SECRET: A long, random string used to HMAC-sign auth tokens.
#   Generate one with: openssl rand -base64 48
#   REQUIRED for production. If unset, an insecure fallback is used.
# -----------------------------------------------------------------------------
TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Pesapal (Tanzania - Mobile Money, Cards, Bank)
# Sign up at https://developer.pesapal.com/
# 1. Create a Pesapal account
# 2. Get your Consumer Key and Consumer Secret from the dashboard
# 3. Set PESAPAL_ENV to "production" when going live (uses "sandbox" by default)
# 4. Register your IPN callback URL: {NEXT_PUBLIC_APP_URL}/api/payments/pesapal/callback
# -----------------------------------------------------------------------------
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=sandbox

# -----------------------------------------------------------------------------
# Stripe (Credit & Debit Cards, International)
# Sign up at https://dashboard.stripe.com/
# 1. Create a Stripe account
# 2. Get API keys from https://dashboard.stripe.com/apikeys
# 3. Create a webhook endpoint in Stripe Dashboard pointing to:
#    {NEXT_PUBLIC_APP_URL}/api/payments/stripe/webhook
#    Events to listen: checkout.session.completed
# 4. Copy the webhook signing secret to STRIPE_WEBHOOK_SECRET
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is safe to expose client-side.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# PayPal (PayPal Account, Cards)
# Sign up at https://developer.paypal.com/
# 1. Create a PayPal Business account
# 2. Go to https://developer.paypal.com/dashboard/applications/live
#    (or /applications/sandbox for testing)
# 3. Create a REST API App to get Client ID and Secret
# 4. Set PAYPAL_ENV to "production" when going live (uses "sandbox" by default)
# 5. Set up webhook in PayPal Developer Dashboard pointing to:
#    {NEXT_PUBLIC_APP_URL}/api/payments/paypal/webhook
#    Events to listen: CHECKOUT.ORDER.APPROVED
# -----------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
