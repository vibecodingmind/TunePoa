# ===========================================
# TunePoa Environment Variables
# ===========================================
# Copy this file as .env.local for local dev
# On Railway, add these in Variables tab

# ── App ──
NEXT_PUBLIC_APP_URL=https://tunepoa.com
TOKEN_SECRET=generate-one-with-openssl-rand-base64-48

# ── Database (auto-set by Railway PostgreSQL plugin) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Pesapal ──
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=sandbox

# ── Stripe ──
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── PayPal ──
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# ── Google reCAPTCHA (optional) ──
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Email / SMTP (optional) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tunepoa.com
